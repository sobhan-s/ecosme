    "@sanity/vision": "^5.18.0",
    "@types/nodemailer": "^7.0.11",
    "better-auth": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^1.6.0",
    "next": "16.2.1",
    "next-sanity": "^12.1.1",
    "nodemailer": "^8.0.3",
    "pg": "^8.20.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^5.6.0",
    "sanity": "^5.14.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7"
